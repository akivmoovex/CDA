NODE_ENV=development
PORT=3000

# Base domain for subdomain tenant resolution (e.g. cda-platform.test)
APP_BASE_DOMAIN=localhost

# Comma-separated hostnames that map to the platform default tenant
PLATFORM_HOSTS=localhost,127.0.0.1

# Supabase (PostgreSQL + Auth + Storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage buckets (paths always start with tenant slug, e.g. cda-kafue/programs/photo.jpg):
# - tenant-media (public): approved images, galleries, program photos, logos
# - resources (public): downloadable PDFs (reports, policies, publications)
# - private-documents (private): consent forms, child-related pending media, internal docs

# Optional local admin bypass (never enable in production)
DEV_AUTH_ENABLED=false
DEV_AUTH_USER_ID=dev-user
DEV_AUTH_EMAIL=dev@example.com
DEV_AUTH_ROLE=tenant_admin
DEV_AUTH_TENANT_ID=cda-kafue
