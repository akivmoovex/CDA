<%#
  Admin sidebar navigation
  Uses: adminNavItems, adminNavFooterItems, currentPath, tenant, isNavActive helper via inline logic
%>
<aside class="admin-sidebar hidden w-64 shrink-0 flex-col bg-surface-container py-md md:flex">
  <div class="mb-lg px-sm">
    <div class="mb-xs flex items-center gap-sm px-sm">
      <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary text-on-primary">
        <span class="material-symbols-outlined">volunteer_activism</span>
      </div>
      <div>
        <h2 class="font-display text-headline-md leading-none text-primary"><%= typeof tenant !== 'undefined' && tenant ? (tenant.name.split(' ').slice(-1)[0] || 'CDAK') : 'CDAK' %></h2>
        <p class="text-label-md text-on-surface-variant">Staff Portal</p>
      </div>
    </div>
  </div>

  <nav aria-label="Admin navigation" class="flex-1 space-y-xs overflow-y-auto px-sm custom-scrollbar">
    <% adminNavItems.forEach(function(item) { %>
      <% const active = item.match.some(function(path) { return currentPath === path || (path !== '/admin' && currentPath.startsWith(path)); }); %>
      <a
        href="<%= item.href %>"
        class="<%= active ? 'bg-primary-container font-bold text-on-primary-container' : 'text-on-surface-variant hover:bg-surface-variant' %> flex items-center gap-md rounded-lg px-md py-sm transition-colors"
      >
        <span class="material-symbols-outlined"><%= item.icon %></span>
        <span class="text-label-md"><%= item.label %></span>
      </a>
    <% }); %>
  </nav>

  <div class="space-y-xs border-t border-outline-variant px-sm pt-md">
    <% adminNavFooterItems.forEach(function(item) { %>
      <% const active = item.match.some(function(path) { return currentPath === path || currentPath.startsWith(path); }); %>
      <a
        href="<%= item.href %>"
        class="<%= active ? 'bg-surface-variant font-bold text-primary' : 'text-on-surface-variant hover:bg-surface-variant' %> flex items-center gap-md rounded-lg px-md py-sm transition-colors"
      >
        <span class="material-symbols-outlined"><%= item.icon %></span>
        <span class="text-label-md"><%= item.label %></span>
      </a>
    <% }); %>
    <a href="/admin/login" class="flex items-center gap-md rounded-lg px-md py-sm text-error transition-colors hover:bg-error-container hover:text-on-error-container">
      <span class="material-symbols-outlined">logout</span>
      <span class="text-label-md">Log out</span>
    </a>
    <div class="mt-md px-sm">
      <a href="/" class="block w-full rounded-lg bg-secondary py-sm text-center text-label-md text-on-secondary transition-opacity hover:opacity-90">
        View Website
      </a>
    </div>
  </div>
</aside>
