<%# Locals: event (object), variant ('default'|'highlight') %>
<% const item = event; %>
<% const cardVariant = typeof variant !== 'undefined' ? variant : 'default'; %>

<% if (cardVariant === 'highlight') { %>
  <article class="flex gap-md rounded-xl border border-secondary/20 bg-secondary-container/20 p-md transition-all hover:bg-secondary-container/30">
    <div class="flex min-w-[80px] flex-col items-center justify-center rounded-lg bg-secondary p-4 text-white">
      <span class="text-xs font-bold uppercase"><%= item.month %></span>
      <span class="text-2xl font-bold"><%= item.day %></span>
    </div>
    <div>
      <h3 class="mb-1 font-display text-label-md text-primary"><%= item.title %></h3>
      <p class="mb-2 text-caption text-on-surface-variant"><%= item.summary %></p>
      <span class="flex items-center gap-1 text-xs font-bold text-secondary">
        <span class="material-symbols-outlined text-sm">location_on</span>
        <%= item.location %>
      </span>
    </div>
  </article>
<% } else { %>
  <article class="flex gap-4 rounded-xl border border-outline-variant bg-surface-container p-4 transition-transform hover:translate-x-2">
    <div class="flex min-w-[70px] flex-col justify-center rounded-lg bg-primary px-4 py-2 text-center text-white">
      <span class="text-xs uppercase"><%= item.month %></span>
      <span class="text-2xl font-bold"><%= item.day %></span>
    </div>
    <div>
      <h3 class="font-bold text-primary"><%= item.title %></h3>
      <p class="text-sm text-on-surface-variant"><%= item.summary %></p>
      <p class="mt-1 flex items-center gap-1 text-sm text-on-surface-variant">
        <span class="material-symbols-outlined text-xs">location_on</span>
        <%= item.location %>
      </p>
    </div>
  </article>
<% } %>
