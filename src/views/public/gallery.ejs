<%- include('../partials/hero', {
  variant: 'page',
  badge: 'Gallery',
  title: 'Moments of Impact',
  subtitle: 'A visual journey through our programs, community partnerships, and the children we serve.',
  image: galleryItems.length ? galleryItems[0].image : programs[0].image,
  primaryCta: { label: 'Support Our Work', href: '/donate' },
  secondaryCta: { label: 'Read Our Stories', href: '/news' }
}) %>

<section class="page-section">
  <div class="site-shell">
    <div class="mb-8 flex flex-wrap gap-3">
      <% ['All', 'Education', 'Health', 'Empowerment', 'Community', 'Stories'].forEach(function(filter, index) { %>
        <button type="button" class="<%= index === 0 ? 'bg-secondary text-white' : 'border border-outline-variant bg-white text-primary' %> rounded-full px-4 py-2 text-sm font-bold transition-colors">
          <%= filter %>
        </button>
      <% }); %>
    </div>
    <div class="grid gap-md sm:grid-cols-2 lg:grid-cols-3">
      <% if (!galleryItems.length) { %>
        <p class="col-span-full text-body-md text-on-surface-variant">Approved gallery media will appear here once published by the media team.</p>
      <% } %>
      <% galleryItems.forEach(function(item, index) { %>
        <figure class="group overflow-hidden rounded-xl border border-outline-variant bg-white <%= index === 0 ? 'sm:col-span-2 sm:row-span-2' : '' %>">
          <div class="<%= index === 0 ? 'h-[420px]' : 'h-56' %> overflow-hidden">
            <img src="<%= item.image %>" alt="<%= item.title %>" class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <figcaption class="p-4">
            <span class="impact-chip mb-2"><%= item.category %></span>
            <h3 class="font-display text-headline-md text-primary"><%= item.title %></h3>
          </figcaption>
        </figure>
      <% }); %>
    </div>
  </div>
</section>

<%- include('../partials/cta-section', {
  title: 'Share Your Photos With Us',
  subtitle: 'Community members and volunteers can submit images for review and inclusion in our gallery.',
  primaryCta: { label: 'Contact Media Team', href: '/contact' },
  secondaryCta: { label: 'View Programs', href: '/programs' },
  variant: 'primary'
}) %>
