<%
  const tableRows = items.map(function(item) {
    const row = {};
    config.listColumns.forEach(function(column) {
      if (column.type === 'status') {
        row[column.key] = {
          status: item.status === 'published' ? 'success' : 'pending',
          label: item.status,
        };
      } else {
        row[column.key] = item[column.key] ?? '—';
      }
    });
    row.actions = {
      editHref: config.adminBase + '/' + item.id + '/edit',
      publishAction: config.adminBase + '/' + item.id + '/publish',
      unpublishAction: config.adminBase + '/' + item.id + '/unpublish',
      deleteAction: config.adminBase + '/' + item.id + '/delete',
      isPublished: item.status === 'published',
    };
    return row;
  });

  const tableColumns = config.listColumns.concat([{ key: 'actions', label: 'Actions', align: 'right' }]);
%>

<div class="mb-lg flex flex-col justify-between gap-md md:flex-row md:items-end">
  <div>
    <h1 class="font-display text-headline-lg text-primary"><%= pageTitle %></h1>
    <p class="mt-1 text-body-md text-on-surface-variant">Manage <%= config.label.toLowerCase() %> for <%= tenant.name %>.</p>
  </div>
  <% if (typeof topbarAction !== 'undefined' && topbarAction) { %>
    <a href="<%= topbarAction.href %>" class="btn-primary"><%= topbarAction.label %></a>
  <% } %>
</div>

<% if (typeof flash !== 'undefined' && flash) { %>
  <div class="mb-md rounded-lg border border-secondary/30 bg-secondary-container/20 px-md py-sm text-sm text-primary">
    Record <%= flash %> successfully.
  </div>
<% } %>

<%- include('../../partials/admin/cms-table', {
  columns: tableColumns,
  rows: tableRows,
  emptyMessage: 'No ' + config.label.toLowerCase() + ' yet.'
}) %>

<div class="h-xl"></div>
