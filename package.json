{
  "name": "cda-platform",
  "version": "0.1.0",
  "description": "Multi-tenant NGO website platform for Child Development Agency Kafue",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:css\" \"npm run dev:server\"",
    "dev:server": "node --watch src/server.js",
    "dev:css": "tailwindcss -i ./public/css/input.css -o ./public/dist/styles.css --watch",
    "build:css": "tailwindcss -i ./public/css/input.css -o ./public/dist/styles.css --minify",
    "build": "npm run build:css",
    "start": "node src/server.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "compression": "^1.8.0",
    "dotenv": "^16.5.0",
    "ejs": "^3.1.10",
    "express": "^5.1.0",
    "express-ejs-layouts": "^2.5.1",
    "helmet": "^8.1.0",
    "multer": "^2.0.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.17"
  }
}
